# ─── Chaves de API ─────────────────────────────────────────────────────────
# Onde gerar:
#   TMDB:      https://www.themoviedb.org/settings/api
#   Anthropic: https://console.anthropic.com/settings/keys
TMDB_API_KEY=
ANTHROPIC_API_KEY=

# ─── Analytics (opcional, mas recomendado) ────────────────────────────────
# Cole o Measurement ID do GA4 (formato G-XXXXXXXXXX).
# Como criar: https://analytics.google.com → Admin → Streams → Web → Measurement ID
NEXT_PUBLIC_GA_ID=

# Cole o Pixel ID do Meta (numérico, 15-16 dígitos).
# Como criar: https://business.facebook.com/events_manager → "+ Conectar fontes" → Web → Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Newsletter (Beehiiv) ─────────────────────────────────────────────────
# Cadastro em https://www.beehiiv.com/sign-up (plano Launch é grátis até 2.500 subs).
# A API Key é gerada em Settings > Integrations > API.
# O Publication ID (formato pub_xxxx-xxxx-xxxx) está em Settings > Publication info.
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ─── Afiliado Ingresso.com via Awin ───────────────────────────────────────
# Após aprovação no programa Ingresso Partners da Awin, cole o deep link aqui.
# Formato típico: https://www.awin1.com/cread.php?awinmid=XXXXX&awinaffid=YYYYY&ued=https%3A%2F%2Fwww.ingresso.com%2F
# Se vazio, o site cai no link direto ingresso.com (sem comissão).
NEXT_PUBLIC_INGRESSO_AWIN_URL=
