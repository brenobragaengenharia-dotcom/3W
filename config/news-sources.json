{
  "$doc": "Fontes para fetch-news.js. Escopo: entretenimento, comics, esportes.",
  "rss": [
    { "nome": "Omelete",            "url": "https://www.omelete.com.br/feed",             "categoria_padrao": "Cinema",     "tags_hint": ["cinema","series"] },
    { "nome": "AdoroCinema",        "url": "https://www.adorocinema.com/rss/noticias/",   "categoria_padrao": "Cinema",     "tags_hint": ["cinema","filmes"] },
    { "nome": "Legiao dos Herois",  "url": "https://legiaodosherois.uol.com.br/feed",     "categoria_padrao": "Cultura Pop","tags_hint": ["marvel","dc"] },
    { "nome": "Jovem Nerd",         "url": "https://jovemnerd.com.br/feed/",              "categoria_padrao": "Cultura Pop","tags_hint": ["geek"] },
    { "nome": "Canaltech",          "url": "https://canaltech.com.br/entretenimento/rss/","categoria_padrao": "Séries",     "tags_hint": ["series","streaming"] },
    { "nome": "Universo HQ",        "url": "https://www.universohq.com/feed/",            "categoria_padrao": "Comics",     "tags_hint": ["quadrinhos"] },
    { "nome": "ESPN Brasil",        "url": "https://www.espn.com.br/espn/rss/news",       "categoria_padrao": "Esportes",   "tags_hint": ["futebol","nba","f1"] },
    { "nome": "Globo Esporte",      "url": "https://ge.globo.com/rss/ge.xml",              "categoria_padrao": "Esportes",   "tags_hint": ["futebol"] },
    { "nome": "Grande Prêmio F1",   "url": "https://www.grandepremio.com.br/feed",        "categoria_padrao": "Fórmula 1",  "tags_hint": ["f1"] }
  ],
  "gnews": {
    "enabled": true,
    "queries": [
      { "q": "Marvel OR DC OR Pixar OR Disney+",                  "categoria_padrao": "Cinema",     "max": 3 },
      { "q": "Netflix OR HBO Max OR Prime Video OR Apple TV",     "categoria_padrao": "Séries",     "max": 3 },
      { "q": "HQ OR quadrinhos OR mangá OR anime",                "categoria_padrao": "Comics",     "max": 2 },
      { "q": "Brasileirão OR Champions OR seleção brasileira",    "categoria_padrao": "Futebol",    "max": 3 },
      { "q": "NBA OR LeBron OR Curry OR playoffs",                "categoria_padrao": "NBA",        "max": 2 },
      { "q": "Fórmula 1 OR Verstappen OR Hamilton",               "categoria_padrao": "Fórmula 1",  "max": 2 }
    ]
  },
  "limites": {
    "max_noticias_por_rodada": 8,
    "max_por_categoria": 3,
    "max_por_array": 40,
    "min_palavras_corpo_original": 30,
    "idade_maxima_horas": 48
  },
  "categorias_aceitas": ["Cinema", "Séries", "Comics", "Cultura Pop", "Futebol", "NBA", "Fórmula 1", "Esportes"]
}
