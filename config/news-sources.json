  "gnews": {
    "enabled": true,
    "queries": [
      { "q": "Marvel OR DC OR \"Star Wars\" OR Pixar OR Disney+",          "categoria_padrao": "Cinema",     "max": 3 },
      { "q": "Netflix OR HBO Max OR \"Prime Video\" OR \"Apple TV\"",    "categoria_padrao": "Séries",     "max": 3 },
      { "q": "HQ OR quadrinhos OR mangá OR anime OR \"Marvel Comics\" OR \"DC Comics\"", "categoria_padrao": "Comics", "max": 2 },
      { "q": "Brasileirão OR Champions OR \"seleção brasileira\" OR Libertadores","categoria_padrao": "Futebol","max": 3 },
      { "q": "NBA OR LeBron OR Curry OR playoffs",                            "categoria_padrao": "NBA",        "max": 2 },
      { "q": "\"Fórmula 1\" OR Verstappen OR Hamilton OR GP",                "categoria_padrao": "Fórmula 1",  "max": 2 }
    ]
  },
  "limites": {
    "max_noticias_por_rodada": 8,
    "max_por_categoria": 3,
    "max_por_array": 40,
    "min_palavras_corpo_original": 30,
    "idade_maxima_horas": 48
  },
  "categorias_aceitas": ["Cinema", "Séries", "Comics", "Cultura Pop", "Futebol", "NBA", "Fórmula 1", "Esportes"]
}
