{
  "$doc": "Fontes para o fetch-news.js. Edite livremente.",
  "rss": [
    { "nome": "Omelete",          "url": "https://www.omelete.com.br/rss/feed",         "categoria_padrao": "Cinema",     "tags_hint": ["cinema","series"] },
    { "nome": "Legiao dos Herois","url": "https://legiaodosherois.uol.com.br/feed",     "categoria_padrao": "Cultura Pop","tags_hint": ["marvel","dc"] },
    { "nome": "Jovem Nerd",       "url": "https://jovemnerd.com.br/feed/",              "categoria_padrao": "Cultura Pop","tags_hint": ["geek"] },
    { "nome": "Adrenaline",       "url": "https://www.adrenaline.com.br/feed/",         "categoria_padrao": "Games",      "tags_hint": ["games"] },
    { "nome": "IGN Brasil",       "url": "https://br.ign.com/feed.xml",                 "categoria_padrao": "Games",      "tags_hint": ["games"] },
    { "nome": "ESPN Brasil",      "url": "https://www.espn.com.br/espn/rss/news",       "categoria_padrao": "Esportes",   "tags_hint": ["nba","f1","futebol"] },
    { "nome": "Universo HQ",      "url": "https://www.universohq.com/feed/",            "categoria_padrao": "Comics",     "tags_hint": ["quadrinhos"] }
  ],
  "gnews": {
    "enabled": true,
    "queries": [
      { "q": "Marvel OR DC OR Disney+",                        "categoria_padrao": "Cinema",     "max": 4 },
      { "q": "PlayStation OR Xbox OR Nintendo OR Steam",       "categoria_padrao": "Games",      "max": 4 },
      { "q": "Brasileirão OR Champions OR seleção brasileira", "categoria_padrao": "Futebol",    "max": 3 },
      { "q": "NBA playoffs OR LeBron OR Curry",                "categoria_padrao": "NBA",        "max": 2 },
      { "q": "\"Fórmula 1\" OR \"F1\" OR Verstappen OR Hamilton","categoria_padrao": "Fórmula 1","max": 2 }
    ]
  },
  "limites": {
    "max_noticias_por_rodada": 8,
    "max_por_categoria": 3,
    "max_por_array": 40,
    "min_palavras_corpo_original": 30,
    "idade_maxima_horas": 36
  }
}
